# Copy this file to `.env` (same folder as manage.py) and fill in your own
# local PostgreSQL details. `.env` is read automatically on server start and
# is git-ignored, so real credentials never get committed.

DB_NAME=billing_system
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Optional: only needed if you want the app to send real emails instead of
# printing them to the console. See README.md "Sending real emails".
# EMAIL_BACKEND=smtp
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=you@gmail.com
